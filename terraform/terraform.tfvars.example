# =============================================================================
# Terraform Variables Example
# =============================================================================
# Copy this file to terraform.tfvars and update values for your environment.
# At minimum, you MUST set model_bucket_arn to your actual S3 bucket ARN.
# =============================================================================

# Name of the EKS cluster
cluster_name = "voiceai-eks"

# AWS region where all resources will be deployed
aws_region = "us-east-1"

# Single availability zone for all resources (must have g5 GPU instance capacity)
availability_zone = "us-east-1a"

# EKS Kubernetes version (must be 1.31 or later)
kubernetes_version = "1.31"

# CIDR block for the VPC
vpc_cidr = "10.0.0.0/16"

# REQUIRED - You must change this value!
# ARN of the S3 bucket containing your model weights.
# Replace with the ARN of your actual S3 bucket.
model_bucket_arn = "arn:aws:s3:::your-model-bucket-name"

# IAM Identity Center group IDs for Grafana admin access (optional)
# Example: ["group-id-1", "group-id-2"]
grafana_admin_groups = []
