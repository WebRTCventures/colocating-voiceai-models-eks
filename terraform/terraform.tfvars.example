# =============================================================================
# Terraform Variables Example
# =============================================================================
# Copy this file to terraform.tfvars and adjust values for your environment.
# All variables have sensible defaults — no changes required for us-east-1.
# =============================================================================

# Name of the EKS cluster
cluster_name = "voiceai-eks"

# AWS region where all resources will be deployed
aws_region = "us-east-1"

# Primary availability zone for GPU workloads (must have g5 capacity)
availability_zone = "us-east-1a"

# EKS Kubernetes version (must be 1.31 or later)
kubernetes_version = "1.31"

# CIDR block for the VPC
vpc_cidr = "10.0.0.0/16"
